# ===========================================
# Cartelle Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# Supabase Configuration
# ===========================================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key - KEEP SECRET! Never expose this client-side
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Application Configuration
# ===========================================
# Your application's public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://cartelle.app

# ===========================================
# Admin Configuration
# ===========================================
# Comma-separated list of admin email addresses
# These users will have access to /admin routes
ADMIN_EMAILS=admin@cartelle.app
NEXT_PUBLIC_ADMIN_EMAILS=admin@cartelle.app

# ===========================================
# WhatsApp Integration
# ===========================================
# Whapi gateway (legacy fallback)
WHAPI_API_KEY=your-whapi-api-key-here

# WhatsApp Business API (Meta Cloud API)
# Used for webhook signature validation
META_WHATSAPP_APP_SECRET=your-meta-app-secret-here
# Optional: global webhook verify token
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here

# ===========================================
# CRON Jobs (renewal reminders)
# ===========================================
# Secret to authenticate cron calls
CRON_SECRET=your-cron-secret-here

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================
# SENTRY_DSN=https://your-sentry-dsn
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
